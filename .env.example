# open-harness-atlas — environment variables (all optional)
#
# Copy this file to `.env` and fill in only the values you need.
# Nothing in this repo *requires* a key — the static atlas works without any.

# ---------------------------------------------------------------------------
# Metadata refresh (scripts/refresh_metadata.py)
# ---------------------------------------------------------------------------
# A GitHub personal access token (classic, no scopes needed for public repos)
# raises the API rate limit from 60/hour to 5000/hour. Strongly recommended
# if you are refreshing the full registry. The `gh auth login` CLI token
# is auto-detected if this is empty.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Interactive companion (companion/, make companion)
# ---------------------------------------------------------------------------
# Local Neo4j connection for the optional knowledge-graph companion.
# The Makefile's `make neo4j-local` target launches a Neo4j 5 container
# pre-configured with these defaults.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-please
