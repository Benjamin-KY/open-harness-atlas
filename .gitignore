# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# pytest / coverage / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Environment / secrets — NEVER commit these
.env
.env.*
!.env.example
*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs / transient runs
logs/
*.log
tmp/

# Companion app (generated on demand, never committed)
companion/app/

# Rendered visuals are checked in (canonical SVGs); PDFs / raster exports are not
visuals/**/*.pdf
visuals/**/*.png
!visuals/**/preview.png

# Node / docs tooling (if added later)
node_modules/
